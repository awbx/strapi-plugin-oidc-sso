{
  "name": "strapi-plugin-oidc-sso",
  "version": "0.1.0",
  "description": "Generic OIDC SSO for the Strapi v5 admin panel.",
  "keywords": [
    "strapi",
    "plugin",
    "oidc",
    "sso",
    "openid-connect",
    "auth"
  ],
  "license": "MIT",
  "author": {
    "name": "Abdelhadi Sabani",
    "email": "asabani.work@gmail.com",
    "url": "https://github.com/awbx"
  },
  "homepage": "https://github.com/awbx/strapi-plugin-oidc-sso#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awbx/strapi-plugin-oidc-sso.git"
  },
  "bugs": {
    "url": "https://github.com/awbx/strapi-plugin-oidc-sso/issues"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.26.2",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "admin",
    "server",
    "strapi-admin.js",
    "strapi-server.js"
  ],
  "scripts": {
    "build": "strapi-plugin build && tsc -p tsconfig.build.json",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify"
  },
  "dependencies": {
    "generate-password": "^1.7.1",
    "jose": "^5.9.6",
    "openid-client": "^5.7.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@strapi/sdk-plugin": "^5.3.2",
    "@strapi/strapi": "^5.0.0",
    "@strapi/typescript-utils": "^5.0.0",
    "@types/koa": "^2.15.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.6.2",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "@strapi/strapi": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "oidc-sso",
    "displayName": "OIDC SSO",
    "description": "Login to Strapi admin via any OpenID Connect provider."
  }
}
