{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
  },
  "include": ["server", "admin", "strapi-admin.js", "strapi-server.js"],
  "exclude": ["node_modules", "dist", "build"]
}
